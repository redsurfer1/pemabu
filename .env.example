# ── Local Vault (Docker `db` service) ───────────────────────────────────────
# Internal URL when running inside Compose (hostname `db`).
LOCAL_DB_URL=postgresql://pemabu:pemabu_local_only@db:5432/pemabu_vault
# Host port mapping (see docker-compose.yml VAULT_DB_PORT)
# LOCAL_DB_URL=postgresql://pemabu:pemabu_local_only@127.0.0.1:5433/pemabu_vault

# ── Sovereign deployment (see docs/DEPLOYMENT.md) ─────────────────────────────
# Vault mode (true): required for trade approval, execution queue, exchange API keys.
# Cloud workbook (false): OK for dashboard/marketplace; NEVER set EXECUTION_LIVE_MODE=true.
USE_LOCAL_VAULT=false
# Set true only when intentionally pointing at Supabase Cloud Postgres (not recommended).
SUPABASE_CLOUD_OK=false

# Used by Watcher entrypoint `pg_isready` (docker-compose sets these for `worker`).
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=pemabu
PGDATABASE=pemabu_vault
PGPASSWORD=change_me_in_prod

VAULT_POSTGRES_PASSWORD=change_me_in_prod
VAULT_DB_PORT=5433
APP_PORT=3000

# Ephemeral relay (no portfolio payload; Bearer key only).
FLOMISMA_RELAY_KEY=
FLOMISMA_RELAY_URL=http://127.0.0.1:8787/v1/relay

# Local vault encryption (AES-256-GCM for exchange_credentials). Min 16 chars; never commit real values.
MASTER_VAULT_KEY=
# Optional scrypt salt override (default baked in lib/security/encryption.ts).
MASTER_VAULT_KDF_SALT=

# Force stub trade failure code when approving (e.g. BALANCE_INSUFFICIENT) for circuit-breaker tests.
PEMABU_STUB_FORCE_TRADE_ERROR=

# ── Next.js / Supabase (session + hosted data when not on full local vault) ─
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only (see lib/env.ts for full production set)
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
PEMABU_CRON_SECRET=
ANTHROPIC_API_KEY=
# Optional override for Strategy Council monthly memo (default: Claude Sonnet).
STRATEGY_COUNCIL_ANTHROPIC_MODEL=
# Licensed market data — Tiingo paid tier (required for production).
MARKET_DATA_PROVIDER=tiingo
RESEND_API_KEY=
RESEND_FROM_EMAIL=
OPERATOR_ALERT_EMAIL=
TIINGO_API_KEY=

# ── Marketplace import token ledger ──────────────────────────────────────────
# Controls import entitlement model:
#   (unset, default): uses marketplace_import_ledger (per-import token balance)
#   false:            emergency rollback — uses legacy marketplace_unlocks path
# The ledger path requires the following migrations to have been applied:
#   supabase/migrations/[timestamp]_import_token_spend_rpc.sql
#   supabase/migrations/[timestamp]_backfill_existing_unlocks_to_ledger.sql
# Set to "false" ONLY for a rollback. Remove or leave unset for normal operation.
# MARKETPLACE_USE_IMPORT_LEDGER=false

# ── Stripe ────────────────────────────────────────────────────────────────────
# Single webhook endpoint handles all events: POST /api/stripe/webhook
# Register these event types in the Stripe Dashboard for that endpoint:
#   checkout.session.completed
#   invoice.paid
#   customer.subscription.deleted
#
# Marketplace blueprint unlock:       POST /api/stripe/create-checkout-session
# SaaS subscription purchase:        POST /api/stripe/create-subscription-checkout
#   renewal_mode=auto  → Stripe Subscription (recurring, dunning, Customer Portal)
#   renewal_mode=manual → one-time annual payment (user manually renews each year)
# Customer Portal (auto users only):  POST /api/stripe/customer-portal
#   Configure the portal at: https://dashboard.stripe.com/settings/billing/portal
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Exchange Execution Mode ───────────────────────────────────────────────────
# Requires USE_LOCAL_VAULT=true. Set to "true" ONLY with paper/sandbox broker creds first.
# When absent or any other value, dispatchOrder() returns stub responses (no broker REST).
# NEVER enable on Vercel/cloud (USE_LOCAL_VAULT=false) — see docs/DEPLOYMENT.md.
EXECUTION_LIVE_MODE=false

# ── ALPACA ────────────────────────────────────────────────────────────────────
# Paper trading credentials from https://alpaca.markets (always use paper first)
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Set to "true" ONLY after paper trading is fully validated
ALPACA_USE_LIVE=false

# ── KRAKEN ────────────────────────────────────────────────────────────────────
# API key from https://www.kraken.com/u/security/api
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ── COINBASE ADVANCED TRADE ───────────────────────────────────────────────────
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=
# Set to "true" to use Coinbase sandbox endpoint (legacy exchange sandbox URL)
COINBASE_USE_SANDBOX=true
# Optional override for retail Advanced Trade REST host (default https://api.coinbase.com)
COINBASE_API_BASE=

