# ── Local Vault (Docker `db` service) ───────────────────────────────────────
# Internal URL when running inside Compose (hostname `db`).
LOCAL_DB_URL=postgresql://pemabu:pemabu_local_only@db:5432/pemabu_vault
# Host port mapping (see docker-compose.yml VAULT_DB_PORT)
# LOCAL_DB_URL=postgresql://pemabu:pemabu_local_only@127.0.0.1:5433/pemabu_vault

USE_LOCAL_VAULT=false
# Set true only when intentionally pointing at Supabase Cloud Postgres (not recommended).
SUPABASE_CLOUD_OK=false

# Used by Watcher entrypoint `pg_isready` (docker-compose sets these for `worker`).
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=pemabu
PGDATABASE=pemabu_vault
PGPASSWORD=change_me_in_prod

VAULT_POSTGRES_PASSWORD=change_me_in_prod
VAULT_DB_PORT=5433
APP_PORT=3000

# Ephemeral relay (no portfolio payload; Bearer key only).
FLOMISMA_RELAY_KEY=
FLOMISMA_RELAY_URL=http://127.0.0.1:8787/v1/relay

# Local vault encryption (AES-256-GCM for exchange_credentials). Min 16 chars; never commit real values.
MASTER_VAULT_KEY=
# Optional scrypt salt override (default baked in lib/security/encryption.ts).
MASTER_VAULT_KDF_SALT=

# Force stub trade failure code when approving (e.g. BALANCE_INSUFFICIENT) for circuit-breaker tests.
PEMABU_STUB_FORCE_TRADE_ERROR=

# ── Next.js / Supabase (session + hosted data when not on full local vault) ─
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only (see lib/env.ts for full production set)
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
PEMABU_CRON_SECRET=
ANTHROPIC_API_KEY=
# Optional override for Strategy Council monthly memo (default: Claude Sonnet).
STRATEGY_COUNCIL_ANTHROPIC_MODEL=
MARKET_DATA_PROVIDER=google-finance
RESEND_API_KEY=
RESEND_FROM_EMAIL=
OPERATOR_ALERT_EMAIL=
TIINGO_API_KEY=
